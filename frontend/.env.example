# Auth0 configuration
AUTH0_SECRET=CHANGE_ME_TO_A_RANDOM_STRING
AUTH0_BASE_URL=http://localhost:3000
AUTH0_ISSUER_BASE_URL=https://YOUR_AUTH0_DOMAIN
AUTH0_CLIENT_ID=YOUR_AUTH0_CLIENT_ID
AUTH0_CLIENT_SECRET=YOUR_AUTH0_CLIENT_SECRET

# UW-only restriction: only @uw.edu / @washington.edu accounts are accepted.
# Ensure your Auth0 application allows UW login and that email is returned in the profile.

# Optional override for local backend API
NEXT_PUBLIC_API_URL=http://localhost:8000
